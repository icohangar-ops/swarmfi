# =====================================================
# SwarmFi Agent System — Environment Configuration
# =====================================================
# Copy this file to .env and fill in all values.
# SECURITY: The placeholder key below MUST be replaced
# with a real private key before any deployment.

# ── Blockchain ──────────────────────────────────────
INITIA_RPC_URL=https://rpc.testnet.initia.xyz
INITIA_CHAIN_ID=initiation-1

# ── Agent Authentication (REQUIRED) ──────────────────
# SECURITY WARNING: Generate a fresh keypair for production.
# Never reuse the placeholder key. Keep this secret.
# Generate with: solana-keygen new --no-bip39-passphrase
AGENT_PRIVATE_KEY=0x_YOUR_REAL_PRIVATE_KEY_HERE

# ── Logging ─────────────────────────────────────────
LOG_LEVEL=INFO

# ── Consensus ────────────────────────────────────────
CONSENSUS_THRESHOLD=0.67

# ── Stigmergy ───────────────────────────────────────
STIGMERGY_DECAY_RATE=0.1
